<MudPaper Class="@($"volt-empty-state {CssClass}")" Elevation="0">
    @if (!string.IsNullOrWhiteSpace(Icon))
    {
        <MudIcon Icon="@Icon" Size="Size.Large" Color="Color.Default" />
    }
    <MudText Typo="Typo.h6">@Title</MudText>
    @if (!string.IsNullOrWhiteSpace(Description))
    {
        <MudText Typo="Typo.body2" Class="volt-text-muted">@Description</MudText>
    }
    @if (ActionContent is not null)
    {
        <div class="volt-empty-state-action">
            @ActionContent
        </div>
    }
</MudPaper>
