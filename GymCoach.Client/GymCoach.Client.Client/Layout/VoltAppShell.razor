@inherits LayoutComponentBase
@implements IDisposable
@inject ILocalizationService L10n

<div class="volt-app-root" dir="@(L10n.IsRtl ? "rtl" : "ltr")" lang="@L10n.CurrentCulture.TwoLetterISOLanguageName">
    <MudThemeProvider Theme="_theme" IsDarkMode="true" />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />

    <VoltTopBar />

    <main class="volt-shell-main volt-page-content volt-animate-in">
        @Body
    </main>

    <VoltBottomNav />
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private readonly MudTheme _theme = VoltMudTheme.Create();

    protected override void OnInitialized() => L10n.CultureChanged += OnCultureChanged;

    private void OnCultureChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => L10n.CultureChanged -= OnCultureChanged;
}
