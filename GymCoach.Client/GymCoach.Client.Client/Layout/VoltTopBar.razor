@inject ILocalizationService L10n
@inject NavigationManager Navigation

<header class="volt-topbar">
    <div class="d-flex align-center gap-2">
        <span class="volt-logo-mark" aria-hidden="true">⚡</span>
        <MudText Typo="Typo.h6" Class="volt-logo-text">@L10n["AppName"]</MudText>
    </div>
    <MudSpacer />
    <MudButtonGroup Variant="Variant.Outlined" Color="Color.Default" Class="volt-lang-toggle">
        <MudButton OnClick="@(() => SetLang("en"))"
                   Class="@(L10n.CurrentCulture.TwoLetterISOLanguageName == "en" ? "volt-lang-active" : "")">
            @L10n["Lang.En"]
        </MudButton>
        <MudButton OnClick="@(() => SetLang("fa"))"
                   Class="@(L10n.CurrentCulture.TwoLetterISOLanguageName == "fa" ? "volt-lang-active" : "")">
            @L10n["Lang.Fa"]
        </MudButton>
    </MudButtonGroup>
</header>

@code {
    private async Task SetLang(string code) => await L10n.SetCultureAsync(code);
}
